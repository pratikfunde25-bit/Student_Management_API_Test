# Environment Variables — Backend
# Copy this file to .env and fill in your actual values
# NEVER commit the real .env file to Git

# ─── Server ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ────────────────────────────────────────────────────
# Local MongoDB (default for development)
MONGO_URI=mongodb://127.0.0.1:27017/student-management

# Cloud MongoDB (for production — get this from MongoDB Atlas)
# MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/student-management?retryWrites=true&w=majority

# ─── Security ────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_64_CHARACTER_SECRET
JWT_EXPIRES_IN=7d

# ─── Encryption (for guardian phone numbers) ─────────────────────
# Must be exactly 32 characters (256-bit AES key)
ENCRYPTION_KEY=REPLACE_WITH_32_CHARACTER_KEY_HERE

# ─── CORS ────────────────────────────────────────────────────────
# In development: http://localhost:5173 (Vite default)
# In production: your deployed frontend URL
CORS_ORIGIN=http://localhost:5173
